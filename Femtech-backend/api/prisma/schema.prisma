  questions             QuizQuestion[]
  milestone_definitions MilestoneDefinition? @relation(fields: [milestone_def_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([category], map: "idx_quizzes_category")
  @@index([country], map: "idx_quizzes_country")
  @@map("quizzes")
}

model QuizQuestion {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  quizId         String        @map("quiz_id") @db.Uuid
