generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma-client"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, uuid_ossp(map: "uuid-ossp", schema: "public")]
}

model User {
  id                                               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone                                            String             @unique(map: "users_phone_unique") @db.VarChar(20)
  phoneVerified                                    Boolean            @default(false) @map("phone_verified")
  phone_verified_at                                DateTime?          @db.Timestamptz(6)
  country                                          country_code
  language                                         language_code      @default(en)
  status                                           user_status        @default(pending)
  role                                             user_role          @default(mother)
  walletAddress                                    String?            @unique(map: "users_wallet_unique") @map("wallet_address") @db.VarChar(56)
  walletCreatedAt                                  DateTime?          @map("wallet_created_at") @db.Timestamptz(6)
  lastLoginAt                                      DateTime?          @map("last_login_at") @db.Timestamptz(6)
  login_count                                      Int                @default(0)
  createdAt                                        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointments_appointments_user_idTousers         Appointment[]      @relation("appointments_user_idTousers")
  appointments                                     Appointment[]
  audit_logs                                       audit_logs[]
  circle_members_circle_members_invited_byTousers  CircleMember[]     @relation("circle_members_invited_byTousers")
  circleMembers                                    CircleMember[]
  consents                                         Consent[]
  digital_doulas_digital_doulas_user_idTousers     DigitalDoula?      @relation("digital_doulas_user_idTousers")
  digital_doulas_digital_doulas_verified_byTousers DigitalDoula[]     @relation("digital_doulas_verified_byTousers")
  emergency_contacts                               EmergencyContact[]
  kick_sessions                                    KickSession[]
  medical_history_medical_history_user_idTousers   MedicalHistory[]   @relation("medical_history_user_idTousers")
  medicalHistory                                   MedicalHistory[]
  notifications                                    Notification[]
  pregnancies                                      Pregnancy[]
  quizAttempts                                     QuizAttempt[]
  redemptions                                      Redemption[]
  sessions                                         Session[]
  sms_messages                                     SmsMessage[]
  support_circles                                  SupportCircle[]
  tokenTransactions                                TokenTransaction[]
  milestones                                       UserMilestone[]
  profile                                          UserProfile?
  verifier                                         Verifier[]

  @@index([country], map: "idx_users_country")
  @@index([createdAt], map: "idx_users_created_at")
  @@index([phone], map: "idx_users_phone")
  @@index([status], map: "idx_users_status")
  @@map("users")
}

model UserProfile {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId               String   @unique(map: "user_profiles_user_unique") @map("user_id") @db.Uuid
  firstNameEncrypted   Bytes?   @map("first_name_encrypted")
  lastNameEncrypted    Bytes?   @map("last_name_encrypted")
  dateOfBirthEncrypted Bytes?   @map("date_of_birth_encrypted")
  avatarUrl            String?  @map("avatar_url") @db.VarChar(500)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_user_profiles_user_id")
  @@map("user_profiles")
}

model Consent {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  consentType consent_type @map("consent_type")
  version     String       @db.VarChar(20)
  granted     Boolean
  grantedAt   DateTime?    @map("granted_at") @db.Timestamptz(6)
  revokedAt   DateTime?    @map("revoked_at") @db.Timestamptz(6)
  ipAddress   String?      @map("ip_address") @db.Inet
  userAgent   String?      @map("user_agent")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, consentType, version], map: "consents_user_type_unique")
  @@index([consentType], map: "idx_consents_type")
  @@index([userId], map: "idx_consents_user_id")
  @@map("consents")
}

model Session {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  deviceId         String?  @map("device_id") @db.VarChar(100)
  device_info      Json?
  ipAddress        String?  @map("ip_address") @db.Inet
  refreshTokenHash String   @unique(map: "sessions_token_unique") @map("refresh_token_hash") @db.VarChar(64)
  expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
  last_used_at     DateTime @default(now()) @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@index([refreshTokenHash], map: "idx_sessions_token_hash")
  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

model OtpCode {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone       String      @db.VarChar(20)
  codeHash    String      @map("code_hash") @db.VarChar(64)
  purpose     otp_purpose
  attempts    Int         @default(0)
  maxAttempts Int         @default(3) @map("max_attempts")
  expiresAt   DateTime    @map("expires_at") @db.Timestamptz(6)
  verified_at DateTime?   @db.Timestamptz(6)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt], map: "idx_otp_codes_expires_at")
  @@index([phone], map: "idx_otp_codes_phone")
  @@index([phone, purpose], map: "idx_otp_codes_phone_purpose")
  @@map("otp_codes")
}

model Facility {
  id               String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String        @db.VarChar(200)
  type             facility_type
  address          String?
  city             String?       @db.VarChar(100)
  country          country_code
  latitude         Decimal?      @db.Decimal(10, 8)
  longitude        Decimal?      @db.Decimal(11, 8)
  phone            String?       @db.VarChar(20)
  email            String?       @db.VarChar(255)
  website          String?       @db.VarChar(500)
  operatingHours   Json?         @map("operating_hours")
  isPartner        Boolean       @default(false) @map("is_partner")
  partner_since    DateTime?     @db.Date
  accepts_tokens   Boolean       @default(false)
  verificationCode String?       @map("verification_code") @db.VarChar(20)
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointments     Appointment[]
  pregnancies      Pregnancy[]
  verifiers        Verifier[]

  @@index([country], map: "idx_facilities_country")
  @@index([type], map: "idx_facilities_type")
  @@map("facilities")
}

model Pregnancy {
  id                   String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId               String           @map("user_id") @db.Uuid
  status               pregnancy_status @default(active)
  last_period_date     DateTime?        @db.Date
  estimated_due_date   DateTime         @db.Date
  conceptionDate       DateTime?        @map("conception_date") @db.Date
  actual_delivery_date DateTime?        @db.Date
  gravida              Int              @default(1)
  parity               Int              @default(0)
  isHighRisk           Boolean          @default(false) @map("is_high_risk")
  riskFactors          Json?            @map("risk_factors")
  risk_score           Int?
  bloodType            blood_type?      @default(unknown) @map("blood_type")
  primaryFacilityId    String?          @map("primary_facility_id") @db.Uuid
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointments         Appointment[]
  kickSessions         KickSession[]
  medicalHistory       MedicalHistory[]
  primaryFacility      Facility?        @relation(fields: [primaryFacilityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  support_circles      SupportCircle[]
  milestones           UserMilestone[]

  @@index([estimated_due_date], map: "idx_pregnancies_due_date")
  @@index([status], map: "idx_pregnancies_status")
  @@index([userId], map: "idx_pregnancies_user_id")
  @@map("pregnancies")
}

model MedicalHistory {
  id                                   String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                              String           @db.Uuid
  pregnancyId                          String?          @map("pregnancy_id") @db.Uuid
  conditionType                        condition_type   @map("condition_type")
  condition_code                       String?          @db.VarChar(20)
  condition_name                       String           @db.VarChar(200)
  status                               condition_status @default(active)
  diagnosedDate                        DateTime?        @map("diagnosed_date") @db.Date
  resolved_date                        DateTime?        @db.Date
  notesEncrypted                       Bytes?           @map("notes_encrypted")
  verifiedBy                           String?          @map("verified_by") @db.Uuid
  verifiedAt                           DateTime?        @map("verified_at") @db.Timestamptz(6)
  createdAt                            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                            DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  pregnancy                            Pregnancy?       @relation(fields: [pregnancyId], references: [id], onUpdate: NoAction)
  users_medical_history_user_idTousers User             @relation("medical_history_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  verifier                             User?            @relation(fields: [verifiedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([pregnancyId], map: "idx_medical_history_pregnancy_id")
  @@index([conditionType], map: "idx_medical_history_type")
  @@index([user_id], map: "idx_medical_history_user_id")
  @@map("medical_history")
}

model Appointment {
  id                                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                           String             @db.Uuid
  pregnancyId                       String?            @map("pregnancy_id") @db.Uuid
  facilityId                        String?            @map("facility_id") @db.Uuid
  appointment_type                  appointment_type
  status                            appointment_status @default(scheduled)
  scheduled_at                      DateTime           @db.Timestamptz(6)
  duration_minutes                  Int?               @default(30)
  reminder_sent_at                  DateTime?          @db.Timestamptz(6)
  completed_at                      DateTime?          @db.Timestamptz(6)
  verified_at                       DateTime?          @db.Timestamptz(6)
  verifiedBy                        String?            @map("verified_by") @db.Uuid
  verification_code                 String?            @db.VarChar(20)
  notes                             String?
  createdAt                         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  facility                          Facility?          @relation(fields: [facilityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pregnancy                         Pregnancy?         @relation(fields: [pregnancyId], references: [id], onUpdate: NoAction)
  users_appointments_user_idTousers User               @relation("appointments_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  verifier                          User?              @relation(fields: [verifiedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([facilityId], map: "idx_appointments_facility_id")
  @@index([pregnancyId], map: "idx_appointments_pregnancy_id")
  @@index([scheduled_at], map: "idx_appointments_scheduled_at")
  @@index([status], map: "idx_appointments_status")
  @@index([user_id], map: "idx_appointments_user_id")
  @@map("appointments")
}

model KickSession {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String    @db.Uuid
  pregnancyId     String    @map("pregnancy_id") @db.Uuid
  start_time      DateTime  @db.Timestamptz(6)
  end_time        DateTime? @db.Timestamptz(6)
  kickCount       Int       @default(0) @map("kick_count")
  target_count    Int       @default(10)
  durationMinutes Int?      @map("duration_minutes")
  notes           String?
  alertTriggered  Boolean   @default(false) @map("alert_triggered")
  alert_reason    String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  pregnancy       Pregnancy @relation(fields: [pregnancyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([pregnancyId], map: "idx_kick_sessions_pregnancy_id")
  @@index([start_time], map: "idx_kick_sessions_start_time")
  @@index([user_id], map: "idx_kick_sessions_user_id")
  @@map("kick_sessions")
}

model EmergencyContact {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String   @db.Uuid
  name         String   @db.VarChar(100)
  relationship String   @db.VarChar(50)
  phone        String   @db.VarChar(20)
  priority     Int      @default(1)
  is_active    Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  users        User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_emergency_contacts_user_id")
  @@map("emergency_contacts")
}

model MilestoneDefinition {
  id                      String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code                    String              @db.VarChar(50)
  name                    String              @db.VarChar(200)
  description             String?
  icon                    String?             @db.VarChar(50)
  category                milestone_category
  country                 country_code?
  rewardAmount            Int                 @map("reward_amount")
  maxClaimsPerPregnancy   Int                 @default(1) @map("max_claims_per_pregnancy")
  requiresVerification    Boolean             @default(true) @map("requires_verification")
  verificationTypes       verification_type[] @default([qr_scan]) @map("verification_types")
  gestationalWeekMin      Int?                @map("gestational_week_min")
  gestationalWeekMax      Int?                @map("gestational_week_max")
  days_to_complete        Int?
  prerequisite_milestones String[]            @db.Uuid
  isActive                Boolean             @default(true) @map("is_active")
  sortOrder               Int                 @default(0) @map("sort_order")
  createdAt               DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  quizzes                 Quiz[]
  user_milestones         UserMilestone[]

  @@unique([code, country], map: "milestone_definitions_code_country_unique")
  @@index([category], map: "idx_milestone_definitions_category")
  @@index([code], map: "idx_milestone_definitions_code")
  @@index([country], map: "idx_milestone_definitions_country")
  @@map("milestone_definitions")
}

model UserMilestone {
  id                    String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                String              @map("user_id") @db.Uuid
  pregnancyId           String?             @map("pregnancy_id") @db.Uuid
  milestone_def_id      String              @db.Uuid
  status                milestone_status    @default(available)
  progress              Int                 @default(0)
  progressData          Json?               @map("progress_data")
  startedAt             DateTime?           @map("started_at") @db.Timestamptz(6)
  completedAt           DateTime?           @map("completed_at") @db.Timestamptz(6)
  expiresAt             DateTime?           @map("expires_at") @db.Timestamptz(6)
  rewardAmount          Int?                @map("reward_amount")
  reward_minted         Boolean             @default(false)
  reward_tx_hash        String?             @db.VarChar(64)
  reward_minted_at      DateTime?           @db.Timestamptz(6)
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  token_transactions    TokenTransaction[]
  milestone_definitions MilestoneDefinition @relation(fields: [milestone_def_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pregnancy             Pregnancy?          @relation(fields: [pregnancyId], references: [id], onUpdate: NoAction)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  verifications         Verification[]

  @@unique([userId, pregnancyId, milestone_def_id], map: "user_milestones_unique")
  @@index([milestone_def_id], map: "idx_user_milestones_def_id")
  @@index([pregnancyId], map: "idx_user_milestones_pregnancy_id")
  @@index([status], map: "idx_user_milestones_status")
  @@index([userId], map: "idx_user_milestones_user_id")
  @@map("user_milestones")
}

model Verifier {
  id                  String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId              String?        @map("user_id") @db.Uuid
  facilityId          String?        @map("facility_id") @db.Uuid
  verifier_type       verifier_type
  verificationCode    String         @unique(map: "verifiers_code_unique") @map("verification_code") @db.VarChar(20)
  name                String         @db.VarChar(200)
  credential_number   String?        @db.VarChar(100)
  credential_verified Boolean        @default(false)
  total_verifications Int            @default(0)
  isActive            Boolean        @default(true) @map("is_active")
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  verifications       Verification[]
  facility            Facility?      @relation(fields: [facilityId], references: [id], onUpdate: NoAction)
  user                User?          @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([verificationCode], map: "idx_verifiers_code")
  @@index([facilityId], map: "idx_verifiers_facility_id")
  @@index([verifier_type], map: "idx_verifiers_type")
  @@index([userId], map: "idx_verifiers_user_id")
  @@map("verifiers")
}

model Verification {
  id               String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userMilestoneId  String            @map("user_milestone_id") @db.Uuid
  verifierId       String?           @map("verifier_id") @db.Uuid
  verificationType verification_type @map("verification_type")
  verificationHash String            @map("verification_hash") @db.VarChar(64)
  qrCodeData       String?           @map("qr_code_data")
  signature        Bytes?
  metadata         Json?
  latitude         Decimal?          @db.Decimal(10, 8)
  longitude        Decimal?          @db.Decimal(11, 8)
  verified_at      DateTime          @default(now()) @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  userMilestone    UserMilestone     @relation(fields: [userMilestoneId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  verifier         Verifier?         @relation(fields: [verifierId], references: [id], onUpdate: NoAction)

  @@index([verificationHash], map: "idx_verifications_hash")
  @@index([userMilestoneId], map: "idx_verifications_milestone_id")
  @@index([verified_at], map: "idx_verifications_verified_at")
  @@index([verifierId], map: "idx_verifications_verifier_id")
  @@map("verifications")
}

model TokenTransaction {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  type            token_tx_type
  status          token_tx_status @default(pending)
  amount          Int
  tx_hash         String?         @db.VarChar(64)
  stellar_tx_id   String?         @db.VarChar(64)
  milestoneId     String?         @map("milestone_id") @db.Uuid
  redemptionId    String?         @map("redemption_id") @db.Uuid
  errorMessage    String?         @map("error_message")
  retryCount      Int             @default(0) @map("retry_count")
  processed_at    DateTime?       @db.Timestamptz(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  user_milestones UserMilestone?  @relation(fields: [milestoneId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  redemption      Redemption?     @relation(fields: [redemptionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "token_transactions_redemption_fk")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt], map: "idx_token_tx_created_at")
  @@index([milestoneId], map: "idx_token_tx_milestone_id")
  @@index([status], map: "idx_token_tx_status")
  @@index([type], map: "idx_token_tx_type")
  @@index([userId], map: "idx_token_tx_user_id")
  @@map("token_transactions")
}

model Partner {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String           @db.VarChar(200)
  type            partner_type
  country         country_code
  logoUrl         String?          @map("logo_url") @db.VarChar(500)
  description     String?
  api_endpoint    String?          @db.VarChar(500)
  apiKeyEncrypted Bytes?           @map("api_key_encrypted")
  webhookUrl      String?          @map("webhook_url") @db.VarChar(500)
  config          Json?
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  products        PartnerProduct[]
  redemptions     Redemption[]

  @@index([country], map: "idx_partners_country")
  @@index([type], map: "idx_partners_type")
  @@map("partners")
}

model PartnerProduct {
  id                   String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId            String           @map("partner_id") @db.Uuid
  name                 String           @db.VarChar(200)
  description          String?
  category             product_category
  tokenCost            Int              @map("token_cost")
  external_product_id  String?          @db.VarChar(100)
  imageUrl             String?          @map("image_url") @db.VarChar(500)
  is_available         Boolean          @default(true)
  stockQuantity        Int?             @map("stock_quantity")
  max_per_user_daily   Int?
  max_per_user_monthly Int?
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  partner              Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  redemptions          RedemptionItem[]

  @@index([category], map: "idx_partner_products_category")
  @@index([partnerId], map: "idx_partner_products_partner_id")
  @@map("partner_products")
}

model Redemption {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId            String             @map("user_id") @db.Uuid
