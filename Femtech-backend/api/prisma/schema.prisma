  passed           Boolean
  answers          Json
  started_at       DateTime @db.Timestamptz(6)
  completedAt      DateTime @map("completed_at") @db.Timestamptz(6)
  duration_seconds Int?
  rewardGranted    Boolean  @default(false) @map("reward_granted")
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  quiz             Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([quizId], map: "idx_quiz_attempts_quiz_id")
  @@index([userId], map: "idx_quiz_attempts_user_id")
  @@map("quiz_attempts")
}

