  @@index([quizId, sortOrder], map: "idx_quiz_questions_order")
  @@index([quizId], map: "idx_quiz_questions_quiz_id")
  @@map("quiz_questions")
}

model QuizAttempt {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  quizId           String   @map("quiz_id") @db.Uuid
