{
  "name": "@femtech/shared",
  "version": "1.0.0",
  "description": "Shared utilities, types, database clients, and base classes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./database": {
      "import": "./dist/database/index.js",
      "require": "./dist/database/index.js",
      "types": "./dist/database/index.d.ts"
    },
    "./cache": {
      "import": "./dist/cache/cache.service.js",
      "require": "./dist/cache/cache.service.js",
      "types": "./dist/cache/cache.service.d.ts"
    },
    "./services": {
      "import": "./dist/services/base.service.js",
      "require": "./dist/services/base.service.js",
      "types": "./dist/services/base.service.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "amqplib": "^0.10.3",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^3.3.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.4.0",
    "nanoid": "^5.0.6",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}