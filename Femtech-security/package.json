{
  "name": "@femtech/security",
  "version": "1.0.0",
  "description": "Security policies, audits, and vulnerability scanning",
  "private": true,
  "scripts": {
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "scan:deps": "npx snyk test",
    "scan:code": "npx semgrep --config auto .",
    "scan:secrets": "npx trufflehog filesystem --directory=.. --exclude=node_modules",
    "report": "ts-node scripts/generate-security-report.ts",
    "clean": "rimraf reports"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}