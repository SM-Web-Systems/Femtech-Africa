{
  "name": "@femtech/e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for Femtech Africa platform",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:api": "jest --testPathPattern=api",
    "test:web": "playwright test --project=web",
    "test:mobile": "detox test --configuration ios.sim.release",
    "test:report": "playwright show-report",
    "codegen": "playwright codegen",
    "clean": "rimraf test-results playwright-report"
  },
  "dependencies": {
    "@femtech/shared-types": "workspace:*",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "detox": "^20.18.3",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}