{
  "name": "@femtech/ml",
  "version": "1.0.0",
  "description": "Machine learning models for risk assessment and triage",
  "private": true,
  "scripts": {
    "install:python": "pip install -r requirements.txt",
    "dev": "uvicorn app.main:app --reload --port 8000",
    "start": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "train:risk": "python -m scripts.train_risk_model",
    "train:triage": "python -m scripts.train_triage_model",
    "evaluate": "python -m scripts.evaluate_models",
    "test": "pytest",
    "test:coverage": "pytest --cov=app --cov-report=html",
    "lint": "flake8 app scripts",
    "format": "black app scripts",
    "typecheck": "mypy app",
    "clean": "rimraf __pycache__ .pytest_cache .mypy_cache htmlcov"
  },
  "devDependencies": {
    "rimraf": "^5.0.5"
  }
}