{
  "name": "@femtech/localizations",
  "version": "1.0.0",
  "description": "Internationalization and localization resources",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./locales/*": "./locales/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.build.json",
    "clean": "rimraf dist",
    "validate": "ts-node scripts/validate-translations.ts",
    "extract": "ts-node scripts/extract-strings.ts",
    "compile": "ts-node scripts/compile-messages.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "i18next": "^23.10.0",
    "intl-messageformat": "^10.5.11"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}