
# ===========================================
# FEMTECH AFRICA ENVIRONMENT CONFIGURATION
# ===========================================

# Application
NODE_ENV=development
LOG_LEVEL=debug

# ===========================================
# DATABASE - PostgreSQL (Your Server)
# ===========================================
DATABASE_URL=postgresql://femtech_user:your_secure_password@localhost:5432/femtech_db?schema=public
DATABASE_POOL_SIZE=10

# ===========================================
# DATABASE - MongoDB
# ===========================================
MONGODB_URL=mongodb://localhost:27017/femtech_health

# ===========================================
# CACHE - Redis
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===========================================
# MESSAGE QUEUE - RabbitMQ
# ===========================================
RABBITMQ_URL=amqp://femtech:femtech_dev@localhost:5672

# ===========================================
# SERVICE PORTS
# ===========================================
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
HEALTH_SERVICE_PORT=3002
MILESTONE_SERVICE_PORT=3003
TOKEN_SERVICE_PORT=3004
REDEMPTION_SERVICE_PORT=3005
WEB_PORT=4000
ADMIN_PORT=4001

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===========================================
# ENCRYPTION (for PII)
# ===========================================
ENCRYPTION_KEY=32-byte-encryption-key-for-pii-data

# ===========================================
# STELLAR BLOCKCHAIN
# ===========================================
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_ISSUER_SECRET=your-stellar-issuer-secret-key
STELLAR_DISTRIBUTION_SECRET=your-stellar-distribution-secret-key
MOM_TOKEN_CODE=MTK

# ===========================================
# SMS - Africa's Talking
# ===========================================
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=FemTech

# ===========================================
# PUSH NOTIFICATIONS - Firebase
# ===========================================
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ===========================================
# FILE STORAGE - AWS S3 (Optional)
# ===========================================
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=femtech-uploads

# ===========================================
# PARTNER APIs
# ===========================================
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=your-mpesa-shortcode

MTN_MOMO_API_KEY=your-mtn-momo-api-key
MTN_MOMO_USER_ID=your-mtn-momo-user-id
MTN_MOMO_SUBSCRIPTION_KEY=your-mtn-subscription-key

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:4000,http://localhost:4001