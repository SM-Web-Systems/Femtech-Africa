{
  "name": "@femtech/mobile",
  "version": "1.0.0",
  "description": "Femtech Africa React Native Mobile App",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
